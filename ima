      <div class="drop-icon">⬇</div>
      <div class="drop-title">Drop images here</div>
      <div class="drop-sub">Any format → Any format (PNG, JPG, WebP, GIF, BMP, TIFF, ICO, SVG)</div>
    </div>
    <div class="settings-row">
      <div class="field-group" style="flex:2">
        <label>Quality</label>
        <div class="range-wrap">
          <input type="range" id="quality-range" min="10" max="95" value="75" oninput="document.getElementById('quality-val').textContent=this.value+'%'">
          <span class="range-val" id="quality-val">75%</span>
        </div>
      </div>
      <button class="process-btn" onclick="processAll('compress')">Compress all</button>
    </div>
    <div class="prefix-wrap">
      <label>File prefix</label>
      <input type="text" id="prefix-compress" placeholder="image" value="image">
      <span class="prefix-hint">→ image-1.jpg, image-2.jpg …</span>
    </div>
    <div class="file-list" id="list-compress"></div>
    <div class="download-all-wrap" id="dla-compress" style="display:none">
      <span class="summary-badge" id="sum-compress"></span>
      <button class="clear-btn" onclick="clearList('compress')">Clear</button>
      <button class="download-all-btn" onclick="downloadAll('compress')">Download all</button>
    </div>
  </div>

  <!-- RESIZE -->
  <div class="tool-card" id="tab-resize">
    <div class="dropzone" id="dz-resize">
      <input type="file" accept="image/*,.heic,.heif,.avif,.raw,.cr2,.nef,.arw" multiple onchange="handleFiles(this.files,'resize')">
      <div class="drop-icon">↔</div>
      <div class="drop-title">Drop images here</div>
      <div class="drop-sub">Any format → Any format (PNG, JPG, WebP, GIF, BMP, TIFF, ICO, SVG)</div>
    </div>
    <div class="settings-row">
      <div class="field-group">
        <label>Width (px)</label>
        <input type="number" id="resize-w" placeholder="e.g. 1920" min="1" max="8000">
      </div>
      <div class="field-group">
        <label>Height (px)</label>
        <input type="number" id="resize-h" placeholder="Auto" min="1" max="8000">
      </div>
      <div class="field-group" style="min-width:140px">
        <label>Preset</label>
        <select id="resize-preset" onchange="applyPreset()">
          <option value="">Custom</option>
          <option value="1920,1080">1920 × 1080</option>
          <option value="1280,720">1280 × 720</option>
          <option value="800,800">800 × 800</option>
          <option value="1080,1080">1080 × 1080 (Insta)</option>
          <option value="1200,630">1200 × 630 (OG)</option>
          <option value="1080,1920">1080 × 1920 (Story)</option>
        </select>
      </div>
      <button class="process-btn" onclick="processAll('resize')">Resize all</button>
    </div>
    <div class="prefix-wrap">
      <label>File prefix</label>
      <input type="text" id="prefix-resize" placeholder="image" value="image">
      <span class="prefix-hint">→ image-1.png, image-2.png …</span>
    </div>
    <div class="file-list" id="list-resize"></div>
    <div class="download-all-wrap" id="dla-resize" style="display:none">
      <span class="summary-badge" id="sum-resize"></span>
      <button class="clear-btn" onclick="clearList('resize')">Clear</button>
      <button class="download-all-btn" onclick="downloadAll('resize')">Download all</button>
    </div>
  </div>

  <!-- CONVERT -->
  <div class="tool-card" id="tab-convert">
    <div class="dropzone" id="dz-convert">
      <input type="file" accept="image/*,.heic,.heif,.avif,.raw,.cr2,.nef,.arw" multiple onchange="handleFiles(this.files,'convert')">
      <div class="drop-icon">⇄</div>
      <div class="drop-title">Drop images here</div>
      <div class="drop-sub">Any format → Any format (PNG, JPG, WebP, GIF, BMP, TIFF, ICO, SVG)</div>
    </div>
    <div class="settings-row">
      <div class="field-group">
        <label>Convert to</label>
        <select id="convert-fmt">
          <option value="image/jpeg">JPG / JPEG</option>
          <option value="image/png">PNG</option>
          <option value="image/webp">WebP</option>
          <option value="image/gif">GIF</option>
          <option value="image/bmp">BMP</option>
        </select>
      </div>
      <div class="field-group" style="flex:2">
        <label>Quality (JPG / WebP)</label>
        <div class="range-wrap">
          <input type="range" id="convert-quality" min="10" max="95" value="85" oninput="document.getElementById('cq-val').textContent=this.value+'%'">
          <span class="range-val" id="cq-val">85%</span>
        </div>
      </div>
      <button class="process-btn" onclick="processAll('convert')">Convert all</button>
    </div>
    <div class="prefix-wrap">
      <label>File prefix</label>
      <input type="text" id="prefix-convert" placeholder="image" value="image">
      <span class="prefix-hint">→ image-1.webp, image-2.webp …</span>
    </div>
    <div class="file-list" id="list-convert"></div>
    <div class="download-all-wrap" id="dla-convert" style="display:none">
      <span class="summary-badge" id="sum-convert"></span>
      <button class="clear-btn" onclick="clearList('convert')">Clear</button>
      <button class="download-all-btn" onclick="downloadAll('convert')">Download all</button>
    </div>
  </div>

</section>

<footer>100% free · All processing happens in your browser · No files are uploaded or stored</footer>

<script>
/* ── THEME ── */
function setTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  localStorage.setItem('sq-theme', t);
  document.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('btn-' + t).classList.add('active');
}
(function() {
  const t = localStorage.getItem('sq-theme') || 'system';
  document.documentElement.setAttribute('data-theme', t);
  document.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
  const el = document.getElementById('btn-' + t);
  if (el) el.classList.add('active');
})();

/* ── STATE ── */
const state = {
  compress: { files: [], blobs: [] },
  resize:   { files: [], blobs: [] },
  convert:  { files: [], blobs: [] }
};

/* ── TABS ── */
function switchTab(tab) {
  ['compress','resize','convert'].forEach((t,i) => {
    document.querySelectorAll('.tab-btn')[i].classList.toggle('active', t === tab);
  });
  document.querySelectorAll('.tool-card').forEach(c => c.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
}

/* ── DRAG & DROP ── */
['compress','resize','convert'].forEach(t => {
  const dz = document.getElementById('dz-' + t);
  dz.addEventListener('dragover',  e => { e.preventDefault(); dz.classList.add('drag-over'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
  dz.addEventListener('drop',      e => { e.preventDefault(); dz.classList.remove('drag-over'); handleFiles(e.dataTransfer.files, t); });
});

/* ── FILES ── */
function handleFiles(files, tool) {
  Array.from(files).forEach(file => {
    if (!file.type.startsWith('image/')) return;
    state[tool].files.push(file);
    state[tool].blobs.push(null);
    renderItem(tool, state[tool].files.length - 1, file);
  });
}

function renderItem(tool, idx, file) {
  const list = document.getElementById('list-' + tool);
  const item = document.createElement('div');
  item.className = 'file-item';
  item.id = `item-${tool}-${idx}`;
  item.innerHTML = `
    <img class="file-thumb" src="" alt="">
    <div class="file-info">
      <div class="file-name">${file.name}</div>
      <div class="file-meta" id="meta-${tool}-${idx}">${fmtSize(file.size)}</div>
    </div>
    <div class="file-status" id="status-${tool}-${idx}">Pending</div>
    <button class="download-btn" id="dl-${tool}-${idx}" onclick="downloadOne('${tool}',${idx})" style="display:none">↓ Save</button>
  `;
  const r = new FileReader();
  r.onload = e => { const img = item.querySelector('.file-thumb'); if (img) img.src = e.target.result; };
  r.readAsDataURL(file);
  list.appendChild(item);
}

/* ── PROCESS ── */
async function processAll(tool) {
  const files = state[tool].files;
  if (!files.length) { alert('Add some images first!'); return; }
  for (let i = 0; i < files.length; i++) {
    setStatus(tool, i, 'Processing…', 'working');
    try {
      const blob = await processOne(tool, files[i]);
      state[tool].blobs[i] = blob;
      const saved = files[i].size - blob.size;
      const pct   = Math.round((saved / files[i].size) * 100);
      document.getElementById(`meta-${tool}-${i}`).textContent = tool === 'compress'
        ? `${fmtSize(files[i].size)} → ${fmtSize(blob.size)} (${pct > 0 ? '-'+pct+'%' : 'done'})`
        : fmtSize(blob.size);
      setStatus(tool, i, '✓ Done', 'done');
      document.getElementById(`dl-${tool}-${i}`).style.display = 'inline-block';
    } catch(e) { setStatus(tool, i, 'Error', ''); }
  }
  updateSummary(tool);
}

function processOne(tool, file) {
  return new Promise((resolve, reject) => {
    const img = new Image(), url = URL.createObjectURL(file);
    img.onload = () => {
      try {
        const canvas = document.createElement('canvas');
        let w = img.naturalWidth, h = img.naturalHeight;
        if (tool === 'resize') {
          const rw = parseInt(document.getElementById('resize-w').value)||0;
          const rh = parseInt(document.getElementById('resize-h').value)||0;
          if (rw && rh) { w=rw; h=rh; }
          else if (rw)  { h=Math.round((rw/img.naturalWidth)*h); w=rw; }
          else if (rh)  { w=Math.round((rh/img.naturalHeight)*w); h=rh; }
        }
        canvas.width=w; canvas.height=h;
        canvas.getContext('2d').drawImage(img,0,0,w,h);
        let mime=file.type||'image/jpeg', q=0.75;
        if (tool==='compress') { q=parseInt(document.getElementById('quality-range').value)/100; if(mime==='image/png') mime='image/jpeg'; }
        else if (tool==='convert') { mime=document.getElementById('convert-fmt').value; q=parseInt(document.getElementById('convert-quality').value)/100; }
        else if (tool==='resize') { q=0.9; }
        canvas.toBlob(blob => { URL.revokeObjectURL(url); blob?resolve(blob):reject(); }, mime, q);
      } catch(e) { reject(e); }
    };
    img.onerror = reject;
    img.src = url;
  });
}

/* ── DOWNLOAD ── */
const extMap = {'image/jpeg':'jpg','image/jpg':'jpg','image/png':'png','image/webp':'webp','image/gif':'gif','image/bmp':'bmp','image/tiff':'tiff','image/tiff-fx':'tiff','image/x-icon':'ico','image/vnd.microsoft.icon':'ico','image/svg+xml':'svg'};

function getFileName(tool, idx) {
  const prefix = document.getElementById(`prefix-${tool}`).value.trim() || 'image';
  const blob   = state[tool].blobs[idx];
  const mime   = blob ? blob.type : (tool==='convert' ? document.getElementById('convert-fmt').value : 'image/jpeg');
  return `${prefix}-${idx+1}.${extMap[mime]||'jpg'}`;
}

function downloadOne(tool, idx) {
  const blob = state[tool].blobs[idx];
  if (!blob) return;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = getFileName(tool, idx);
  a.click();
  setTimeout(() => URL.revokeObjectURL(a.href), 1000);
}

async function downloadAll(tool) {
  const ready = state[tool].blobs.map((b,i)=>b?i:-1).filter(i=>i>=0);
  if (!ready.length) { alert('Process images first!'); return; }
  if (ready.length===1) { downloadOne(tool, ready[0]); return; }
  if (typeof JSZip !== 'undefined') {
    const zip = new JSZip();
    ready.forEach(i => zip.file(getFileName(tool,i), state[tool].blobs[i]));
    const content = await zip.generateAsync({type:'blob'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(content);
    a.download = `${document.getElementById('prefix-'+tool).value.trim()||'image'}-pack.zip`;
    a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 2000);
  } else {
    for (const i of ready) { downloadOne(tool, i); await new Promise(r=>setTimeout(r,280)); }
  }
}

/* ── HELPERS ── */
function setStatus(tool, idx, text, cls) {
  const el = document.getElementById(`status-${tool}-${idx}`);
  if (el) { el.textContent = text; el.className = 'file-status '+(cls||''); }
}

function fmtSize(b) {
  if (b<1024) return b+' B';
  if (b<1048576) return (b/1024).toFixed(1)+' KB';
  return (b/1048576).toFixed(2)+' MB';
}

function updateSummary(tool) {
  const blobs = state[tool].blobs.filter(Boolean);
  if (!blobs.length) return;
  const total = state[tool].files.reduce((s,f)=>s+f.size,0);
  const out   = blobs.reduce((s,b)=>s+b.size,0);
  const saved = total-out;
  document.getElementById('dla-'+tool).style.display='flex';
  document.getElementById('sum-'+tool).innerHTML = tool==='compress'&&saved>0
    ? `<b>${blobs.length}</b> files · saved <b>${fmtSize(saved)}</b>`
    : `<b>${blobs.length}</b> files ready`;
}

function clearList(tool) {
  state[tool].files=[]; state[tool].blobs=[];
  document.getElementById('list-'+tool).innerHTML='';
  document.getElementById('dla-'+tool).style.display='none';
}

function applyPreset() {
  const val = document.getElementById('resize-preset').value;
  if (!val) return;
  const [w,h] = val.split(',');
  document.getElementById('resize-w').value=w;
  document.getElementById('resize-h').value=h;
}

/* ── PARTICLE ANIMATION ── */
(function initParticles() {
  const canvas = document.getElementById('particle-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let particles = [];
  let mouse = { x: null, y: null, radius: 150 };
  let animationId;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    createParticles();
  }

  function createParticles() {
    particles = [];
    const count = Math.min(80, Math.floor((canvas.width * canvas.height) / 15000));
    for (let i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        size: Math.random() * 2 + 1,
        baseSize: Math.random() * 2 + 1
      });
    }
  }

  function getParticleColor() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark' ||
      (document.documentElement.getAttribute('data-theme') === 'system' &&
       window.matchMedia('(prefers-color-scheme: dark)').matches);
    return isDark ? 'rgba(237, 234, 216, 0.15)' : 'rgba(15, 14, 11, 0.12)';
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const color = getParticleColor();

    particles.forEach((p, i) => {
      // Movement
      p.x += p.vx;
      p.y += p.vy;

      // Bounce off edges
      if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
      if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

      // Mouse interaction
      if (mouse.x !== null && mouse.y !== null) {
        const dx = mouse.x - p.x;
        const dy = mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < mouse.radius) {
          const force = (mouse.radius - dist) / mouse.radius;
          p.x -= dx * force * 0.02;
          p.y -= dy * force * 0.02;
          p.size = p.baseSize * (1 + force * 0.5);
        } else {
          p.size += (p.baseSize - p.size) * 0.1;
        }
      }

      // Draw particle
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();

      // Draw connections (grain/noise effect)
      for (let j = i + 1; j < particles.length; j++) {
        const p2 = particles[j];
        const dx = p.x - p2.x;
        const dy = p.y - p2.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < 80) {
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(p2.x, p2.y);
          ctx.strokeStyle = color.replace(/[\d.]+\)$/, (dist / 80 * 0.08).toFixed(3) + ')');
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    });

    animationId = requestAnimationFrame(animate);
  }

  // Event listeners
  window.addEventListener('resize', resize);
  window.addEventListener('mousemove', e => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });
  window.addEventListener('mouseleave', () => {
    mouse.x = null;
    mouse.y = null;
  });

  // Start
  resize();
  animate();
})();

/* ── JSZip ── */
const s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
document.head.appendChild(s);
</script>
</body>
