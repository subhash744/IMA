  <div class="theme-switcher">
    <button class="theme-btn" id="btn-light"  onclick="setTheme('light')">☀ Light</button>
    <button class="theme-btn" id="btn-system" onclick="setTheme('system')">⊙ System</button>
    <button class="theme-btn" id="btn-dark"   onclick="setTheme('dark')">☽ Dark</button>
  </div>
</div>

<section class="hero">
  <div class="logo-pill"><span class="dot"></span>Free · No signup · Instant</div>
  <h1>Your images,<br><em>beautifully</em> handled.</h1>
  <p class="subtitle">Compress, resize, and convert images right in your browser. Nothing uploaded. Nothing stored.</p>
</section>

<section class="tools-section">

  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('compress')">Compress</button>
    <button class="tab-btn" onclick="switchTab('resize')">Resize</button>
    <button class="tab-btn" onclick="switchTab('convert')">Convert</button>
  </div>

  <!-- COMPRESS -->
  <div class="tool-card active" id="tab-compress">
