<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ══ LIGHT (creamy white) ══ */
:root,
[data-theme="light"] {
  --bg:        #FAF8F3;
  --bg-off:    #F2EFE8;
  --bg-hover:  #E8E4DA;
  --card:      #FDFCF8;
  --border:    #DDD8CA;
  --border-md: #C8C2B0;
  --ink:       #0F0E0B;
  --muted:     #6A6050;
  --muted-lt:  #A09070;
  --grid:      rgba(0,0,0,0.055);
  --shadow:    0 2px 32px rgba(0,0,0,0.06);
  --pill-bg:   #0F0E0B;
  --pill-fg:   #FAF8F3;
  --btn-bg:    #0F0E0B;
  --btn-fg:    #FAF8F3;
  --done:      #2A6432;
  --working:   #7A5C10;
}

/* ══ DARK (warm dark) ══ */
[data-theme="dark"] {
  --bg:        #16140F;
  --bg-off:    #1F1D16;
  --bg-hover:  #28261E;
  --card:      #1B1915;
  --border:    #302C22;
  --border-md: #45402F;
  --ink:       #EDEAD8;
  --muted:     #8C8070;
  --muted-lt:  #5C5448;
  --grid:      rgba(255,255,255,0.04);
  --shadow:    0 2px 32px rgba(0,0,0,0.4);
  --pill-bg:   #EDEAD8;
  --pill-fg:   #16140F;
  --btn-bg:    #EDEAD8;
  --btn-fg:    #16140F;
  --done:      #58C06A;
  --working:   #D4A030;
}

/* ══ SYSTEM auto ══ */
@media (prefers-color-scheme: light) {
  [data-theme="system"] {
    --bg:#FAF8F3;--bg-off:#F2EFE8;--bg-hover:#E8E4DA;--card:#FDFCF8;
    --border:#DDD8CA;--border-md:#C8C2B0;--ink:#0F0E0B;--muted:#6A6050;
    --muted-lt:#A09070;--grid:rgba(0,0,0,0.055);--shadow:0 2px 32px rgba(0,0,0,0.06);
    --pill-bg:#0F0E0B;--pill-fg:#FAF8F3;--btn-bg:#0F0E0B;--btn-fg:#FAF8F3;
    --done:#2A6432;--working:#7A5C10;
  }
}
@media (prefers-color-scheme: dark) {
  [data-theme="system"] {
    --bg:#16140F;--bg-off:#1F1D16;--bg-hover:#28261E;--card:#1B1915;
    --border:#302C22;--border-md:#45402F;--ink:#EDEAD8;--muted:#8C8070;
    --muted-lt:#5C5448;--grid:rgba(255,255,255,0.04);--shadow:0 2px 32px rgba(0,0,0,0.4);
    --pill-bg:#EDEAD8;--pill-fg:#16140F;--btn-bg:#EDEAD8;--btn-fg:#16140F;
    --done:#58C06A;--working:#D4A030;
  }
}

html { font-size: 16px; }

body {
  background-color: var(--bg);
  color: var(--ink);
  font-family: 'DM Sans', sans-serif;
  font-weight: 400;
  min-height: 100vh;
  overflow-x: hidden;
  transition: background-color 0.25s, color 0.25s;
  background-image:
    linear-gradient(var(--grid) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid) 1px, transparent 1px);
  background-size: 40px 40px;
}

/* ══ THEME BAR ══ */
.theme-bar {
  position: fixed;
  top: 16px;
  right: 16px;
  z-index: 100;
}

.theme-switcher {
  display: flex;
  gap: 2px;
  background: var(--bg-off);
  border: 1.5px solid var(--border);
  border-radius: 999px;
  padding: 4px;
  transition: background .25s, border-color .25s;
}

.theme-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px 15px;
  border-radius: 999px;
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  transition: all .18s ease;
  white-space: nowrap;
}

.theme-btn.active { background: var(--btn-bg); color: var(--btn-fg); }
.theme-btn:hover:not(.active) { color: var(--ink); background: var(--border); }

/* ══ HERO ══ */
.hero {
  max-width: 860px;
  margin: 0 auto;
  padding: 24px 32px 16px;
  text-align: center;
}

.logo-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--pill-bg);
  color: var(--pill-fg);
  padding: 5px 14px 5px 8px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: .04em;
  margin-bottom: 16px;
  transition: background .25s;
}

.logo-pill .dot {
  width: 8px; height: 8px;
  background: #B8F04A;
  border-radius: 50%;
  display: inline-block;
}

h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -.02em;
  color: var(--ink);
  margin-bottom: 12px;
  transition: color .25s;
}

h1 em { font-style: italic; color: var(--muted); }

.subtitle {
  font-size: 14px;
  color: var(--muted);
  font-weight: 300;
  max-width: 380px;
  margin: 0 auto;
  line-height: 1.5;
}

/* ══ TOOLS SECTION ══ */
.tools-section {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 24px 20px;
}

.tabs {
  display: flex;
  gap: 6px;
  background: var(--bg-off);
  border: 1.5px solid var(--border);
  border-radius: 999px;
  padding: 5px;
  width: fit-content;
  margin: 0 auto 28px;
  transition: background .25s, border-color .25s;
}

.tab-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 10px 38px;
  border-radius: 999px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: var(--muted);
  transition: all .2s ease;
  white-space: nowrap;
}

.tab-btn.active { background: var(--btn-bg); color: var(--btn-fg); }
.tab-btn:hover:not(.active) { color: var(--ink); background: var(--border); }

.tool-card {
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 24px;
  display: none;
  box-shadow: var(--shadow);
  transition: background .25s, border-color .25s;
}

.tool-card.active { display: block; }

.dropzone {
  border: 2px dashed var(--border-md);
  border-radius: 14px;
  padding: 28px 24px;
  text-align: center;
  cursor: pointer;
  transition: all .2s ease;
  background: var(--bg-off);
  position: relative;
}

.dropzone:hover, .dropzone.drag-over {
  border-color: var(--ink);
  background: var(--bg-hover);
}

.dropzone input[type="file"] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  width: 100%;
  height: 100%;
}

.drop-icon {
  width: 40px; height: 40px;
  border: 2px solid var(--border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10px;
  font-size: 18px;
  background: var(--card);
  transition: background .25s;
}

.drop-title {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 4px;
  color: var(--ink);
}

.drop-sub { font-size: 13px; color: var(--muted-lt); }

.settings-row {
  display: flex;
  gap: 12px;
  margin-top: 16px;
  flex-wrap: wrap;
  align-items: flex-end;
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
  min-width: 140px;
}

.field-group label {
  font-size: 11px;
  font-weight: 500;
  color: var(--muted);
  letter-spacing: .07em;
  text-transform: uppercase;
}

.field-group input,
.field-group select {
  background: var(--bg-off);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 10px 14px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--ink);
  outline: none;
  transition: border-color .15s, background .25s, color .25s;
  width: 100%;
}

.field-group input:focus,
.field-group select:focus { border-color: var(--ink); }

.range-wrap { display: flex; align-items: center; gap: 12px; }

.range-wrap input[type="range"] {
  flex: 1;
  -webkit-appearance: none;
  appearance: none;
  height: 4px;
  background: var(--border);
  border-radius: 99px;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background .25s;
}

.range-wrap input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 18px; height: 18px;
  background: var(--btn-bg);
  border-radius: 50%;
  cursor: pointer;
  transition: background .25s;
}

.range-val {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  min-width: 38px;
  text-align: right;
}

.prefix-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 12px;
  flex-wrap: wrap;
}

.prefix-wrap label {
  font-size: 11px;
  font-weight: 500;
  color: var(--muted);
  letter-spacing: .07em;
  text-transform: uppercase;
  white-space: nowrap;
}

.prefix-wrap input {
  background: var(--bg-off);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 8px 13px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  color: var(--ink);
  outline: none;
  width: 170px;
  transition: border-color .15s, background .25s, color .25s;
}

.prefix-wrap input:focus { border-color: var(--ink); }
.prefix-hint { font-size: 11px; color: var(--muted-lt); }

.process-btn {
  background: var(--btn-bg);
  color: var(--btn-fg);
  border: none;
  border-radius: 10px;
  padding: 11px 28px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity .15s, background .25s, color .25s;
  align-self: flex-end;
  height: 42px;
}

.process-btn:hover { opacity: .8; }
.process-btn:disabled { opacity: .4; cursor: not-allowed; }

.download-btn {
  background: var(--btn-bg);
  color: var(--btn-fg);
  border: none;
  border-radius: 8px;
  padding: 7px 14px;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: opacity .15s, background .25s;
  white-space: nowrap;
  flex-shrink: 0;
}

.download-btn:hover { opacity: .75; }

.file-list { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }

.file-item {
  background: var(--bg-off);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 13px 18px;
  display: flex;
  align-items: center;
  gap: 14px;
  animation: fadeUp .2s ease;
  transition: background .25s;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(5px); }
  to   { opacity: 1; transform: translateY(0); }
}

.file-thumb {
  width: 44px; height: 44px;
  border-radius: 8px;
  object-fit: cover;
  background: var(--border);
  flex-shrink: 0;
  border: 1px solid var(--border-md);
}

.file-info { flex: 1; min-width: 0; }

.file-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 3px;
}

.file-meta { font-size: 11px; color: var(--muted-lt); }

.file-status {
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  white-space: nowrap;
}

.file-status.done    { color: var(--done); }
.file-status.working { color: var(--working); }

.download-all-wrap {
  margin-top: 16px;
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  align-items: center;
}

.summary-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--bg-off);
  border: 1.5px solid var(--border);
  border-radius: 999px;
  padding: 4px 13px;
  font-size: 12px;
  color: var(--muted);
  margin-right: auto;
}

.summary-badge b { color: var(--ink); font-weight: 500; }

.download-all-btn {
  background: none;
  border: 1.5px solid var(--ink);
  color: var(--ink);
  border-radius: 10px;
  padding: 9px 22px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all .15s;
}

.download-all-btn:hover { background: var(--btn-bg); color: var(--btn-fg); border-color: var(--btn-bg); }

.clear-btn {
  background: none;
  border: none;
  color: var(--muted-lt);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.clear-btn:hover { color: var(--ink); }

footer {
  text-align: center;
  padding: 16px 32px;
  font-size: 11px;
  color: var(--muted-lt);
  border-top: 1px solid var(--border);
  max-width: 900px;
  margin: 0 auto;
  transition: border-color .25s;
}

@media (max-width: 600px) {
  .hero { padding: 20px 20px 12px; }
  .tool-card { padding: 18px 14px; }
  .tabs { width: 100%; }
  .tab-btn { flex: 1; padding: 8px 6px; font-size: 12px; text-align: center; }
  .settings-row { flex-direction: column; gap: 8px; }
  .theme-bar { top: 10px; right: 10px; }
  .theme-btn { padding: 4px 10px; font-size: 11px; }
  .dropzone { padding: 20px 16px; }
}

.dropzone input[type="file"] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  width: 100%;
  height: 100%;
}

/* ══ PARTICLE CANVAS ══ */
#particle-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  opacity: 0.6;
}

</style>
